      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\sql\ai_insights\merge_ai_recommendations.sql" Link="Sql\merge_ai_recommendations.sql">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\sql\ai_insights\merge_ai_forecasts.sql" Link="Sql\merge_ai_forecasts.sql">
