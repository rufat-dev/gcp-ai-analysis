    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>SoilAiInsightsWorker</RootNamespace>
    <AssemblyName>SoilAiInsightsWorker</AssemblyName>
    <UserSecretsId>soil-ai-insights-worker-dev</UserSecretsId>
